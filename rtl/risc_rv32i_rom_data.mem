// --- Boot Code ---
19000113 // 00: addi x2, x0, 400                         (스택 포인터 초기화)

// --- main 함수 ---
FE010113 // 04: addi x2, x2, -32
00112E23 // 08: sw x1, 28(x2)
00812C23 // 12: sw x8, 24(x2)
02010413 // 16: addi x8, x2, 32
00100793 // 20: addi x15, x0, 1
FEF42623 // 24: sw x15, -20(x8)
FE042423 // 28: sw x0, -24(x8)
0200006F // 32: jal x0, 32                           (점프: .L4로 이동, 현재PC 32 + 32 = 64)

