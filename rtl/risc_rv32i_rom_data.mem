FEC42703 // 64: lw x14, -20(x8)
00A00793 // 68: addi x15, x0, 10
FCE7DEE3 // 72: bge x15, x14, -36                             (조건 만족 시: .L5로 분기, 현재PC 72 - 36 = 36)
                                  
// --- .L6 (종료 무한 루프) ---
0000006F // 76: jal x0, 0                                         (제자리 점프)

// --- adder 함수 ---
FE010113 // 80: addi x2, x2, -32
00112E23 // 84: sw x1, 28(x2)
00812C23 // 88: sw x8, 24(x2)
02010413 // 92: addi x8, x2, 32
FEA42623 // 96: sw x10, -20(x8)
FEB42423 // 100: sw x11, -24(x8)
FEC42703 // 104: lw x14, -20(x8)
FE842783 // 108: lw x15, -24(x8)
